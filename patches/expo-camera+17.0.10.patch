+  fun getAvailableLenses(): List<String> {
+    val targetLensFacing = lensFacing.mapToCharacteristic()
+    val provider = cameraProvider ?: return emptyList()
+
+    return provider.availableCameraInfos
+      .filter { cameraInfo ->
+        try {
+          val info = Camera2CameraInfo.from(cameraInfo)
+          val facing = info.getCameraCharacteristic(CameraCharacteristics.LENS_FACING) as? Int
+          facing == targetLensFacing
+        } catch (_: Exception) {
+          false
+        }
+      }
