+object LensType {
+  const val WIDE = "builtInWideAngleCamera"
+  const val ULTRA_WIDE = "builtInUltraWideCamera"
+  const val TELEPHOTO = "builtInTelephotoCamera"
+
+  fun identify(focalLengths: FloatArray): String? {
+    if (focalLengths.isEmpty()) return null
+    val minFocal = focalLengths.minOrNull() ?: return null
+
+    // Identify by focal length heuristics (physical mm)
+    // Ultra-wide: typically 1.5-3mm (~13mm equivalent)
+    // Wide: typically 4-5.5mm (~26mm equivalent)
+    // Telephoto: typically 6mm+ (~52mm equivalent)
+    return when {
+      minFocal < 3.0f -> ULTRA_WIDE
+      minFocal > 6.0f -> TELEPHOTO
+      else -> WIDE
+    }
+  }
