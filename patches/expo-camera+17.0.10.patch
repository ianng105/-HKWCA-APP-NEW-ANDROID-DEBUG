+  @OptIn(ExperimentalCamera2Interop::class)
+  private fun classifyLens(cameraInfo: CameraInfo): String {
+    val camera2Info = Camera2CameraInfo.from(cameraInfo)
+
+    // Use focal length to identify lens type
+    try {
+      val focalLengths = camera2Info.getCameraCharacteristic(
+        CameraCharacteristics.LENS_INFO_AVAILABLE_FOCAL_LENGTHS
+      ) as? FloatArray
+      if (focalLengths != null && focalLengths.isNotEmpty()) {
+        val minFocal = focalLengths.minOrNull() ?: return "builtInWideAngleCamera"
+        // Ultra-wide: < 3mm, Wide: 3-6mm, Telephoto: > 6mm
+        return when {
+          minFocal < 3.0f -> "builtInUltraWideCamera"
+          minFocal > 6.0f -> "builtInTelephotoCamera"
+          else -> "builtInWideAngleCamera"
+        }
+      }
+    } catch (_: Exception) { /* fall through to default */ }
+
+    return "builtInWideAngleCamera"
+  }
